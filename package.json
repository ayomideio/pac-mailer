{
  "name": "pac-mailer",
  "version": "1.0.0",
  "description": "Desktop SMTP mailer by Developer Pac",
  "main": "electron/main.js",
  "author": "Developer Pac",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "icons:win": "node scripts/build-win-icon.mjs",
    "pack": "npm run build && npm run icons:win && electron-builder --win --x64 --dir",
    "dist": "npm run build && npm run icons:win && electron-builder --win --x64",
    "dist:win": "npm run build && npm run icons:win && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.developerpac.pacmailer",
    "productName": "Pac Mailer",
    "directories": {
      "output": "release"
    },
    "icon": "icon.png",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "icon.png",
      "package.json"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pac Mailer",
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
